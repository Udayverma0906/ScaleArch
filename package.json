{
  "name": "scalearch",
  "displayName": "ScaleArch",
  "publisher": "UdayVerma",
  "description": "This extension will analyze code and gives suggestions to implements better system design patterns to the code for scalability and performance of architecture. Real-time static analysis for TypeScript & JavaScript. Catches DB anti-patterns, performance issues, SOLID violations, and code quality problems — without AI, without cost, without internet. ",
  "version": "1.0.0",
  "license": "MIT",
  "icon": "./assets/images/extension.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Udayverma0906/ScaleArch.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "scalearch",
    "linter",
    "solid",
    "performance",
    "database",
    "code quality",
    "python",
    "java",
    "cpp"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:cpp",
    "onLanguage:c",
    "onCommand:scalearch.analyze"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scalearch.analyze",
        "title": "ScaleArch: Analyze Current File",
        "category": "ScaleArch"
      }
    ],
    "keybindings": [
      {
        "command": "scalearch.analyze",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "ScaleArch",
      "properties": {
        "scalearch.enableDatabase": {
          "type": "boolean",
          "default": true,
          "description": "Enable database anti-pattern rules"
        },
        "scalearch.enablePerformance": {
          "type": "boolean",
          "default": true,
          "description": "Enable performance rules"
        },
        "scalearch.enableSolid": {
          "type": "boolean",
          "default": true,
          "description": "Enable SOLID principle rules (SRP, DIP)"
        },
        "scalearch.enableCodeQuality": {
          "type": "boolean",
          "default": true,
          "description": "Enable code quality rules (function length, complexity, nesting, params, duplicate strings)"
        },
        "scalearch.enableSecurity": {
          "type": "boolean",
          "default": true,
          "description": "Enable security rules"
        },
        "scalearch.maxMethodsPerClass": {
          "type": "number",
          "default": 10,
          "description": "SRP: max methods per class before warning"
        },
        "scalearch.maxFunctionLines": {
          "type": "number",
          "default": 20,
          "description": "Max lines per function before warning"
        },
        "scalearch.maxCyclomaticComplexity": {
          "type": "number",
          "default": 5,
          "description": "Max cyclomatic complexity before warning"
        },
        "scalearch.maxParams": {
          "type": "number",
          "default": 4,
          "description": "Max function parameters before warning"
        },
        "scalearch.maxNestingDepth": {
          "type": "number",
          "default": 4,
          "description": "Max block nesting depth before warning"
        },
        "scalearch.enablePython": {
          "type": "boolean",
          "default": true,
          "description": "Enable Python-specific rules (print(), bare except, mutable defaults, eval, exec, shell=True)"
        },
        "scalearch.enableJava": {
          "type": "boolean",
          "default": true,
          "description": "Enable Java-specific rules (System.out, raw types, empty catch, SQL injection, hardcoded secrets)"
        },
        "scalearch.enableCpp": {
          "type": "boolean",
          "default": true,
          "description": "Enable C/C++ rules (raw new/delete, #define constants, using namespace std, unsafe functions)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.57.2",
    "@typescript-eslint/typescript-estree": "^8.57.2"
  }
}
