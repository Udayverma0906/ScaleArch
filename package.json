{
  "name": "scalearch",
  "displayName": "ScaleArch",
  "publisher": "UdayVerma",
  "description": "Real-time code quality analyzer — JS/TS/Python/Java/C++ — DB, performance, security, SOLID, complexity",
  "version": "2.0.0",
  "license": "MIT",
  "icon": "./assets/images/extension.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Udayverma0906/ScaleArch.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "scalearch",
    "linter",
    "solid",
    "performance",
    "database",
    "code quality",
    "python",
    "java",
    "cpp"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:cpp",
    "onLanguage:c"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scalearch.analyze",
        "title": "ScaleArch: Analyze Current File",
        "category": "ScaleArch"
      }
    ],
    "keybindings": [
      {
        "command": "scalearch.analyze",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "ScaleArch",
      "properties": {
        "scalearch.enableDatabase": {
          "type": "boolean",
          "default": true,
          "description": "Enable database anti-pattern rules"
        },
        "scalearch.enablePerformance": {
          "type": "boolean",
          "default": true,
          "description": "Enable performance rules"
        },
        "scalearch.enableSolid": {
          "type": "boolean",
          "default": true,
          "description": "Enable SOLID principle rules (SRP, DIP)"
        },
        "scalearch.enableCodeQuality": {
          "type": "boolean",
          "default": true,
          "description": "Enable code quality rules"
        },
        "scalearch.enableSecurity": {
          "type": "boolean",
          "default": true,
          "description": "Enable security rules"
        },
        "scalearch.maxMethodsPerClass": {
          "type": "number",
          "default": 10,
          "description": "SRP: max methods per class before warning"
        },
        "scalearch.maxFunctionLines": {
          "type": "number",
          "default": 20,
          "description": "Max lines per function before warning"
        },
        "scalearch.maxCyclomaticComplexity": {
          "type": "number",
          "default": 5,
          "description": "Max cyclomatic complexity before warning"
        },
        "scalearch.maxParams": {
          "type": "number",
          "default": 4,
          "description": "Max function parameters before warning"
        },
        "scalearch.maxNestingDepth": {
          "type": "number",
          "default": 3,
          "description": "Maximum nesting depth (if/for/while/try) before java/ast-deep-nesting fires."
        },
        "scalearch.enablePython": {
          "type": "boolean",
          "default": true,
          "description": "Enable Python-specific rules"
        },
        "scalearch.enableJava": {
          "type": "boolean",
          "default": true,
          "description": "Enable Java-specific rules"
        },
        "scalearch.enableCpp": {
          "type": "boolean",
          "default": true,
          "description": "Enable C/C++ rules"
        },
        "scalearch.enablePythonAst": {
          "type": "boolean",
          "default": true,
          "description": "Enable AST-based analysis for Python files. Requires Python 3.8+."
        },
        "scalearch.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python 3.8+ executable."
        },
        "scalearch.maxPythonFunctionLines": {
          "type": "number",
          "default": 30,
          "description": "Maximum lines in a Python function before py/ast-function-too-long fires."
        },
        "scalearch.maxPythonClassMethods": {
          "type": "number",
          "default": 10,
          "description": "Maximum methods in a Python class before py/ast-class-too-many-methods fires."
        },
        "scalearch.maxPythonInitAssignments": {
          "type": "number",
          "default": 8,
          "description": "Maximum self.x = ... assignments in __init__ before py/ast-init-too-complex fires."
        },
        "scalearch.enableJavaAst": {
          "type": "boolean",
          "default": true,
          "description": "Enable AST-based analysis for Java files via tree-sitter. Regex rules are always active regardless of this setting."
        },
        "scalearch.maxJavaMethodLines": {
          "type": "number",
          "default": 40,
          "description": "Maximum lines in a Java method before java/ast-method-too-long fires."
        },
        "scalearch.maxJavaClassMethods": {
          "type": "number",
          "default": 10,
          "description": "Maximum methods in a Java class before java/ast-class-too-many-methods fires."
        },
        "scalearch.maxJavaParams": {
          "type": "number",
          "default": 4,
          "description": "Maximum parameters in a Java method before java/ast-too-many-params fires."
        },
        "scalearch.maxJavaClassFields": {
          "type": "number",
          "default": 8,
          "description": "Maximum fields in a Java class before java/ast-too-many-fields fires."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.57.2",
    "@typescript-eslint/typescript-estree": "^8.57.2",
    "tree-sitter": "^0.21.1",
    "tree-sitter-java": "^0.21.0"
  }
}
